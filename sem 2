#include <iostream>
#include <vector>

using namespace std;

int task1(vector<int> nums, int k) {
	int size = nums.size();
	if (size < k) return -1;
	int windowSum = 0;
	for (int i = 0; i < k; i++) {
		windowSum += nums[i];
	}
	int maxSum = windowSum;
	for (int i = k; i < size; i++) {
		windowSum += nums[i] - nums[i - k];
		if (windowSum > maxSum) maxSum = windowSum;
	}
	return maxSum;
}

int task2(vector<int> nums, int target) {
	int size = nums.size();
	int left = 0;
	int currentSum = 0;
	int minLen = size + 1;
	for (int right = 0; right < size; right++) {
		currentSum += nums[right];
		while (currentSum >= target) {
			int len = right - left + 1;
			if (len < minLen) minLen = len;
			currentSum -= nums[left];
			left++;
		}
	}
	return (minLen == size + 1) ? 0 : minLen;
}

vector<int> task3(vector<int> nums, int n) {
	int left = 0;
	int right = nums.size() - 1;
	while (left < right) {
		int sum = nums[left] + nums[right];
		if (sum == n) return { left + 1, right + 1 };
		else if (sum < n) left++;
		else right--;
	}
	return {};
}

void main()
{
	vector<int> nums1 = { 2, 1, 5, 1, 3, 2 };
	int k = 3;
	cout << task1(nums1, k) << endl;
	vector<int> nums2 = { 2, 3, 1, 2, 4, 3 };
	int target = 7;
	cout << task2(nums2, target) << endl;
	vector<int> nums3 = { 2, 7, 11, 15 };
	int n = 9;
	vector<int> result = task3(nums3, n);
	cout << result[0] << ", " << result[1] << endl;;
}
