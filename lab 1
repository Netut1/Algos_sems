#include <iostream>
#include <vector>
#include <ctime>
#include <cstdlib>
#include <algorithm>

int f01_access_middle(const int* a, int n) {
    return a[n / 2];
}

int f03_binary_search(const int* a, int n, int key) {
    int lo = 0, hi = n - 1;
    while (lo <= hi) {
        int m = lo + (hi - lo) / 2;
        if (a[m] == key) return m;
        if (a[m] < key) lo = m + 1;
        else hi = m - 1;
    }
    return -1;
}

long long f09_sum(const int* a, int n) {
    long long s = 0;
    for (int i = 0; i < n; ++i) s += a[i];
    return s;
}

void f18_bubble_sort(int* a, int n) {
    for (int i = 0; i < n - 1; ++i)
        for (int j = 0; j < n - 1 - i; ++j)
            if (a[j] > a[j + 1])
                std::swap(a[j], a[j + 1]);
}

int f26_three_sum_naive(const int* a, int n, int target)
{
    for (int i = 0; i < n; i++)
        for (int j = i + 1; j < n; j++)
            for (int k = j + 1; k < n; k++)
                if (a[i] + a[j] + a[k] == target)
                    return 1;
    return 0;
}

std::vector<int> make_random_vector(int n) {
    std::vector<int> vec(n);
    for (int& x : vec)
        x = std::rand() % 1000;
    return vec;
}


int main() {
    const int ms = 1000;
    std::srand(123);

    std::cout << "f01_access_middle:\n";
    for (int n = 1000000; n <= 100000000; n *= 10) {
        std::vector<int> vec = make_random_vector(n);
        clock_t start = clock();
        for (long long i = 0; i < 1000000; ++i) {
            volatile int dummy = f01_access_middle(vec.data(), n);
        }
        clock_t end = clock();
        double time_sec = double(end - start) / CLOCKS_PER_SEC / 1000000;
        std::cout << "n = " << n << ", time = " << time_sec * ms << " s\n";
    }

    std::cout << "\nf03_binary_search:\n";
    for (int n = 1000; n <= 100000000; n *= 10) {
        std::vector<int> vec = make_random_vector(n);
        std::sort(vec.begin(), vec.end());
        int key = vec[n / 2];;
        clock_t start = clock();
        for (int i = 0; i < 10000; ++i) {
            volatile int res = f03_binary_search(vec.data(), n, key);
        }
        clock_t end = clock();
        double time_sec = double(end - start) / CLOCKS_PER_SEC / 10000;
        std::cout << "n = " << n << ", time = " << time_sec * ms << " s\n";
    }

    std::cout << "\nf09_sum:\n";
    for (int n = 1000; n <= 10000000; n *= 10) {
        std::vector<int> vec = make_random_vector(n);
        clock_t start = clock();
        for (int i = 0; i < 100; ++i) {
            volatile long long res = f09_sum(vec.data(), n);
        }
        clock_t end = clock();
        double time_sec = double(end - start) / CLOCKS_PER_SEC / 100;
        std::cout << "n = " << n << ", time = " << time_sec * ms << " s\n";
    }

    std::cout << "\nf18_bubble_sort:\n";
    for (int n = 100; n <= 50000; n *= 2) {
        std::vector<int> original = make_random_vector(n);
        clock_t start = clock();
        f18_bubble_sort(original.data(), n);
        clock_t end = clock();
        double time_sec = double(end - start) / CLOCKS_PER_SEC;
        std::cout << "n = " << n << ", time = " << time_sec * ms << " s\n";
    }

    std::cout << "\nf26_three_sum_naive:\n";
    for (int n = 100; n <= 2000; n += 100) {
        std::vector<int> vec = make_random_vector(n);
        clock_t start = clock();
        for (int rep = 0; rep < 5; ++rep) {
            volatile int res = f26_three_sum_naive(vec.data(), n, 5000);
        }
        clock_t end = clock();
        double time_sec = double(end - start) / CLOCKS_PER_SEC / 5;
        std::cout << "n = " << n << ", time = " << time_sec << " s\n";
    }
    return 0;
}
